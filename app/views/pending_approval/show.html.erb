<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card">
      <div class="card-body text-center py-5">
        <i class="fas fa-hourglass-half fa-3x text-warning mb-3"></i>
        <h2>Account pending approval</h2>
        <p class="text-muted">An administrator must approve your account before you can access the portal.</p>
        <%= button_to destroy_user_session_path, method: :delete, class: 'btn btn-outline-secondary' do %>
          Sign out
        <% end %>
      </div>
    </div>
  </div>
</div>
