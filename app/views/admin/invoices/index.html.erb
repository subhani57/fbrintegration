<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="fbr-page-header mb-0"><i class="fas fa-file-invoice text-primary"></i> All Invoices</h1>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3"><div class="card fbr-stat-card"><div class="card-body py-3"><small class="text-muted">Total</small><div class="h4 mb-0"><%= @stats[:total] %></div></div></div></div>
  <div class="col-md-3"><div class="card fbr-stat-card"><div class="card-body py-3"><small class="text-muted">Submitted</small><div class="h4 mb-0 text-success"><%= @stats[:submitted] %></div></div></div></div>
  <div class="col-md-3"><div class="card fbr-stat-card"><div class="card-body py-3"><small class="text-muted">Failed</small><div class="h4 mb-0 text-danger"><%= @stats[:failed] %></div></div></div></div>
  <div class="col-md-3"><div class="card fbr-stat-card"><div class="card-body py-3"><small class="text-muted">Draft</small><div class="h4 mb-0"><%= @stats[:draft] %></div></div></div></div>
</div>

<%= form_with url: admin_invoices_path, method: :get, local: true, class: 'row g-2 mb-4' do |f| %>
  <div class="col-md-3">
    <%= f.text_field :q, value: params[:q], placeholder: 'Search email, invoice #, buyer, NTN, FBR #…', class: 'form-control' %>
  </div>
  <div class="col-md-3">
    <%= f.select :user_id, options_from_collection_for_select(@users_for_filter, :id, :email, params[:user_id]),
        { include_blank: 'All taxpayers' }, class: 'form-select' %>
  </div>
  <div class="col-md-2">
    <%= f.select :status, options_for_select(%w[draft validated submitting submitted failed approved rejected cancelled], params[:status]),
        { include_blank: 'All statuses' }, class: 'form-select' %>
  </div>
  <div class="col-md-2">
    <%= f.submit 'Filter', class: 'btn btn-primary w-100' %>
  </div>
<% end %>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Date</th>
          <th>Invoice #</th>
          <th>Taxpayer</th>
          <th>Buyer</th>
          <th>Amount</th>
          <th>Status</th>
          <th>FBR</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @invoices.each do |inv| %>
          <tr>
            <td><%= inv.invoice_date %></td>
            <td><%= inv.pdf_display_number %></td>
            <td><%= link_to inv.user&.email, admin_user_path(inv.user) if inv.user %></td>
            <td><%= inv.buyer_name %></td>
            <td><%= number_to_currency(inv.total_amount, unit: 'Rs. ') %></td>
            <td><span class="badge bg-secondary"><%= inv.status %></span></td>
            <td>
              <% if inv.fbr_invoice_id.present? %>
                <span class="badge bg-success">Submitted</span>
              <% else %>
                <span class="badge bg-light text-dark">—</span>
              <% end %>
            </td>
            <td>
              <%= link_to admin_invoice_path(inv), class: 'btn btn-sm btn-outline-primary' do %>
                <i class="fas fa-eye"></i>
              <% end %>
              <% if inv.fbr_invoice_id.present? %>
                <%= link_to download_pdf_admin_invoice_path(inv), class: 'btn btn-sm btn-outline-success' do %>
                  <i class="fas fa-download"></i>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @invoices.respond_to?(:total_count) %>
    <%= render 'shared/pagination_footer',
        collection: @invoices,
        form_path: admin_invoices_path,
        per_options: [30],
        item_label: 'invoices',
        extra_params: params.permit(:q, :user_id, :status).to_h.compact %>
  <% end %>
</div>
