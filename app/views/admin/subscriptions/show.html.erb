<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
  <div>
    <h1 class="fbr-page-header mb-1"><%= @taxpayer.email %></h1>
    <p class="text-muted mb-0"><%= @taxpayer.business_name.presence || 'Taxpayer subscription' %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to admin_user_path(@taxpayer), class: 'btn btn-outline-secondary' do %>
      <i class="fas fa-user"></i> User profile
    <% end %>
    <%= link_to admin_subscriptions_path, class: 'btn btn-outline-secondary' do %>
      <i class="fas fa-arrow-left"></i> All subscriptions
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-5">
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Current status</strong>
        <%= subscription_status_badge(@taxpayer) %>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-5">Status</dt>
          <dd class="col-sm-7"><%= @taxpayer.subscription_status_label %></dd>
          <dt class="col-sm-5">Active until</dt>
          <dd class="col-sm-7"><%= @taxpayer.subscription_active_until&.strftime('%d %B %Y') || '—' %></dd>
          <dt class="col-sm-5">Days remaining</dt>
          <dd class="col-sm-7">
            <% if @taxpayer.subscription_active? %>
              <%= @taxpayer.subscription_days_remaining %> day(s)
            <% else %>
              <span class="text-danger">Expired</span>
            <% end %>
          </dd>
          <dt class="col-sm-5">Monthly fee</dt>
          <dd class="col-sm-7"><%= format_pkr(@taxpayer.monthly_subscription_fee) %></dd>
          <% if @taxpayer.subscription_plan %>
            <dt class="col-sm-5">Plan</dt>
            <dd class="col-sm-7"><%= @taxpayer.subscription_plan.name %></dd>
          <% end %>
        </dl>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><strong>Record payment</strong></div>
      <div class="card-body">
        <%= render 'admin/subscriptions/mark_paid_form', taxpayer: @taxpayer %>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <div class="card">
      <div class="card-header"><strong>Payment history</strong></div>
      <div class="card-body p-0">
        <% if @subscription_payments.any? %>
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Date</th>
                <th>Receipt</th>
                <th>Amount</th>
                <th>Active until</th>
                <th>Recorded by</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              <% @subscription_payments.each do |payment| %>
                <tr>
                  <td class="text-nowrap"><%= payment.created_at.strftime('%d %b %Y') %></td>
                  <td>
                    <% if payment.receipt_number.present? %>
                      <%= link_to payment.receipt_number, admin_subscription_payment_receipt_path(payment), class: 'small' %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                  <td><%= format_pkr(payment.amount) %></td>
                  <td><%= payment.active_until.strftime('%d %b %Y') %></td>
                  <td><%= payment.recorded_by&.email || '—' %></td>
                  <td class="small text-muted"><%= payment.notes.presence || '—' %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class="p-4 text-muted mb-0">No payments recorded yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
