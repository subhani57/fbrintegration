<h1 class="fbr-page-header mb-4"><i class="fas fa-heartbeat text-primary"></i> System Health</h1>
<p class="text-muted">Checked at <%= @report[:checked_at].strftime('%d %b %Y %H:%M:%S %Z') %></p>

<div class="row g-3">
  <div class="col-md-3">
    <div class="card fbr-stat-card"><div class="card-body">
      <small class="text-muted">Database</small>
      <div class="h5 mb-0 <%= @report[:database] ? 'text-success' : 'text-danger' %>"><%= @report[:database] ? 'OK' : 'Down' %></div>
    </div></div>
  </div>
  <div class="col-md-3">
    <div class="card fbr-stat-card"><div class="card-body">
      <small class="text-muted">Redis</small>
      <div class="h5 mb-0 <%= @report[:redis] ? 'text-success' : 'text-danger' %>"><%= @report[:redis] ? 'OK' : 'Down' %></div>
    </div></div>
  </div>
  <div class="col-md-6">
    <div class="card"><div class="card-body">
      <strong>FBR API (24h)</strong>
      <div class="small mt-2">
        Calls: <%= @report[:fbr_api][:calls_24h] %> ·
        Errors: <%= @report[:fbr_api][:errors_24h] %> ·
        Success: <%= @report[:fbr_api][:success_rate] %>%
      </div>
    </div></div>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header"><strong>Sidekiq</strong></div>
  <div class="card-body">
    <% if @report[:sidekiq][:available] %>
      <p class="mb-0">Processed: <%= @report[:sidekiq][:processed] %> · Enqueued: <%= @report[:sidekiq][:enqueued] %> · Busy: <%= @report[:sidekiq][:busy] %></p>
    <% else %>
      <p class="text-muted mb-0">Sidekiq stats unavailable.</p>
    <% end %>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header"><strong>Subscriptions</strong></div>
  <div class="card-body">
    Active: <%= @report[:subscriptions][:active] %> ·
    Expired: <%= @report[:subscriptions][:expired] %> ·
    Expiring soon: <%= @report[:subscriptions][:expiring_soon] %>
  </div>
</div>
