<h1 class="fbr-page-header mb-4"><i class="fas fa-layer-group text-primary"></i> Subscription Plans</h1>

<div class="row g-4">
  <% @plans.each do |plan| %>
    <div class="col-lg-4">
      <div class="card h-100">
        <div class="card-header d-flex justify-content-between">
          <strong><%= plan.name %></strong>
          <span class="badge <%= plan.active? ? 'bg-success' : 'bg-secondary' %>"><%= plan.active? ? 'Active' : 'Inactive' %></span>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3"><%= @users_by_plan[plan.id] || 0 %> subscriber(s)</p>
          <%= form_with model: plan, url: admin_subscription_plan_path(plan), method: :patch, local: true do |f| %>
            <div class="mb-2">
              <%= f.label :monthly_fee, 'Monthly fee (Rs.)', class: 'form-label' %>
              <%= f.number_field :monthly_fee, step: 0.01, class: 'form-control' %>
            </div>
            <div class="mb-2">
              <%= f.label :invoice_limit, 'Invoice limit (blank = unlimited)', class: 'form-label' %>
              <%= f.number_field :invoice_limit, class: 'form-control' %>
            </div>
            <div class="form-check mb-3">
              <%= f.check_box :active, class: 'form-check-input' %>
              <%= f.label :active, 'Plan available', class: 'form-check-label' %>
            </div>
            <%= f.submit 'Save', class: 'btn btn-primary w-100' %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
