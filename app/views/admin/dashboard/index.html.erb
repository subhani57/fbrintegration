<h1 class="fbr-page-header mb-4"><i class="fas fa-shield-alt text-primary"></i> Admin Dashboard</h1>

<div class="row g-3 mb-4">
  <div class="col-md-4 col-lg-2">
    <div class="card fbr-stat-card h-100">
      <div class="card-body">
        <h6 class="text-muted mb-1">Total Users</h6>
        <h3 class="mb-0 text-primary"><%= @users_count %></h3>
        <small class="text-muted"><%= @taxpayers_count %> taxpayers</small>
      </div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card fbr-stat-card h-100">
      <div class="card-body">
        <h6 class="text-muted mb-1">Invoices</h6>
        <h3 class="mb-0 text-primary"><%= @invoices_count %></h3>
        <small class="text-muted"><%= @submitted_count %> submitted</small>
      </div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card fbr-stat-card h-100">
      <div class="card-body">
        <h6 class="text-muted mb-1">Failed</h6>
        <h3 class="mb-0 text-danger"><%= @failed_count %></h3>
      </div>
    </div>
  </div>
  <div class="col-md-4 col-lg-2">
    <div class="card fbr-stat-card h-100 border-warning">
      <div class="card-body">
        <h6 class="text-muted mb-1">Expiring</h6>
        <h3 class="mb-0 text-warning"><%= @subscription_stats[:expiring_soon] %></h3>
        <%= link_to 'Manage', admin_subscriptions_path(status: 'expiring_soon'), class: 'small' %>
      </div>
    </div>
  </div>
  <div class="col-md-8 col-lg-2">
    <div class="card fbr-stat-card h-100 border-primary">
      <div class="card-body d-flex flex-wrap gap-2 align-items-center">
        <%= link_to admin_users_path, class: 'btn btn-outline-primary btn-sm' do %>
          <i class="fas fa-user-plus"></i> New User
        <% end %>
        <%= link_to admin_subscriptions_path, class: 'btn btn-outline-success btn-sm' do %>
          <i class="fas fa-credit-card"></i> Subscriptions
        <% end %>
        <%= link_to admin_invoices_path, class: 'btn btn-outline-primary btn-sm' do %>
          <i class="fas fa-file-invoice"></i> All Invoices
        <% end %>
        <%= link_to admin_fbr_configurations_path, class: 'btn btn-outline-primary btn-sm' do %>
          <i class="fas fa-cogs"></i> FBR Configs
        <% end %>
        <%= link_to admin_reports_path, class: 'btn btn-outline-primary btn-sm' do %>
          <i class="fas fa-chart-bar"></i> Reports
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <h2 class="h5 text-primary mb-3">Recent Invoices</h2>
    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>Invoice #</th>
              <th>Taxpayer</th>
              <th>Buyer</th>
              <th>Amount</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @recent_invoices.each do |inv| %>
              <tr>
                <td><%= inv.invoice_number %></td>
                <td><%= inv.user&.email %></td>
                <td><%= inv.buyer_name %></td>
                <td><%= number_to_currency(inv.total_amount, unit: 'Rs. ') %></td>
                <td><span class="badge bg-secondary"><%= inv.status %></span></td>
                <td><%= link_to 'View', admin_invoice_path(inv), class: 'btn btn-sm btn-outline-primary' %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <% if @failed_invoices.any? %>
      <h2 class="h5 text-danger mb-3">Failed Submissions</h2>
      <div class="card border-danger mb-4">
        <div class="card-body p-0">
          <ul class="list-group list-group-flush">
            <% @failed_invoices.each do |inv| %>
              <li class="list-group-item d-flex justify-content-between align-items-start">
                <div>
                  <strong><%= inv.invoice_number %></strong>
                  <br><small class="text-muted"><%= inv.user&.email %></small>
                  <% if inv.error_message.present? %>
                    <br><small class="text-danger"><%= truncate(inv.error_message, length: 60) %></small>
                  <% end %>
                </div>
                <%= link_to 'View', admin_invoice_path(inv), class: 'btn btn-sm btn-outline-danger' %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <% if @expiring_taxpayers.any? || @expired_taxpayers.any? %>
      <h2 class="h5 text-warning mb-3">Subscription attention</h2>
      <div class="card border-warning mb-4">
        <div class="card-body p-0">
          <ul class="list-group list-group-flush">
            <% @expiring_taxpayers.each do |u| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <strong><%= u.email %></strong>
                  <br><small class="text-warning">Expires <%= u.subscription_active_until.strftime('%d %b') %> (<%= u.subscription_days_remaining %>d)</small>
                </div>
                <%= link_to 'Record payment', admin_subscription_path(u), class: 'btn btn-sm btn-outline-success' %>
              </li>
            <% end %>
            <% @expired_taxpayers.each do |u| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <strong><%= u.email %></strong>
                  <br><small class="text-danger">Expired<%= u.subscription_active_until ? " #{u.subscription_active_until.strftime('%d %b')}" : '' %></small>
                </div>
                <%= link_to 'Record payment', admin_subscription_path(u), class: 'btn btn-sm btn-outline-success' %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <h2 class="h5 text-primary mb-3">Recent Users</h2>
    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>Email</th>
              <th>Role</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @recent_users.each do |u| %>
              <tr>
                <td><%= u.email %></td>
                <td><span class="badge bg-<%= u.admin? ? 'dark' : 'primary' %>"><%= u.role %></span></td>
                <td><%= link_to 'Manage', admin_user_path(u), class: 'btn btn-sm btn-outline-secondary' %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
