<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="fbr-page-header mb-0"><i class="fas fa-cogs text-primary"></i> FBR Configurations</h1>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card fbr-stat-card h-100">
      <div class="card-body py-3">
        <small class="text-muted">Taxpayers</small>
        <div class="h4 mb-0"><%= @stats[:total] %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card fbr-stat-card h-100">
      <div class="card-body py-3">
        <small class="text-muted">Sandbox ready</small>
        <div class="h4 mb-0 text-info"><%= @stats[:sandbox_ready] %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card fbr-stat-card h-100">
      <div class="card-body py-3">
        <small class="text-muted">Production ready</small>
        <div class="h4 mb-0"><%= @stats[:production_ready] %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card fbr-stat-card h-100">
      <div class="card-body py-3">
        <small class="text-muted">Both configured</small>
        <div class="h4 mb-0 text-success"><%= @stats[:fully_ready] %></div>
      </div>
    </div>
  </div>
</div>

<%= form_with url: admin_fbr_configurations_path, method: :get, local: true, class: 'row g-2 mb-4 align-items-end' do |f| %>
  <div class="col-md-5">
    <%= f.label :q, 'Search', class: 'form-label' %>
    <%= f.text_field :q, value: params[:q], class: 'form-control', placeholder: 'Email or business name…' %>
  </div>
  <div class="col-md-4">
    <%= f.label :token, 'Token status', class: 'form-label' %>
    <%= f.select :token,
        options_for_select([
          ['All taxpayers', ''],
          ['Missing any token', 'missing_any'],
          ['Missing sandbox token', 'missing_sandbox'],
          ['Missing production token', 'missing_production'],
          ['Both tokens configured', 'complete']
        ], params[:token]),
        {},
        class: 'form-select', onchange: 'this.form.requestSubmit()' %>
  </div>
  <div class="col-md-3 d-flex gap-2">
    <%= f.submit 'Search', class: 'btn btn-primary' %>
    <% if params[:q].present? || params[:token].present? %>
      <%= link_to 'Clear', admin_fbr_configurations_path, class: 'btn btn-outline-secondary' %>
    <% end %>
  </div>
<% end %>

<div class="card">
  <div class="card-body p-0">
    <% if @users.any? %>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead>
            <tr>
              <th>Taxpayer</th>
              <th><%= fbr_environment_badge('sandbox') %></th>
              <th><%= fbr_environment_badge('production') %></th>
              <th>Active for submissions</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <% configs = user.fbr_configurations.index_by(&:environment) %>
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <span class="fbr-user-avatar" aria-hidden="true">
                      <i class="fas fa-building"></i>
                    </span>
                    <div>
                      <%= link_to user.email, admin_user_path(user), class: 'fw-medium text-decoration-none' %>
                      <% if user.business_name.present? %>
                        <div class="small text-muted"><%= user.business_name %></div>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td><%= fbr_admin_environment_cell(user, 'sandbox', configs['sandbox']) %></td>
                <td><%= fbr_admin_environment_cell(user, 'production', configs['production']) %></td>
                <td><%= fbr_environment_badge(user.default_fbr_environment) %></td>
                <td class="text-end">
                  <%= link_to edit_admin_fbr_configuration_path(user), class: 'btn btn-sm btn-outline-primary' do %>
                    <i class="fas fa-sliders-h"></i> Manage
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5 px-3">
        <i class="fas fa-key fa-2x text-muted mb-3"></i>
        <p class="text-muted mb-3">No taxpayers match your search or filter.</p>
        <%= link_to 'Clear filters', admin_fbr_configurations_path, class: 'btn btn-outline-primary btn-sm' %>
      </div>
    <% end %>
  </div>
  <% if @users.respond_to?(:total_count) %>
    <%= render 'shared/pagination_footer',
        collection: @users,
        form_path: admin_fbr_configurations_path,
        per_options: [30],
        item_label: 'taxpayers',
        extra_params: params.permit(:q, :token).to_h.compact %>
  <% end %>
</div>
