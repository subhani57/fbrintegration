<h1 class="fbr-page-header mb-4"><i class="fas fa-user-tie text-primary"></i> Accountant Assignments</h1>

<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: admin_accountant_clients_path, method: :post, local: true, class: 'row g-2 align-items-end' do |f| %>
      <div class="col-md-5">
        <%= label_tag :accountant_id, 'Accountant user ID', class: 'form-label' %>
        <%= number_field_tag :accountant_id, params[:accountant_id], class: 'form-control', required: true %>
      </div>
      <div class="col-md-5">
        <%= label_tag :client_id, 'Client (taxpayer) user ID', class: 'form-label' %>
        <%= number_field_tag :client_id, params[:client_id], class: 'form-control', required: true %>
      </div>
      <div class="col-md-2"><%= submit_tag 'Assign', class: 'btn btn-primary w-100' %></div>
    <% end %>
    <p class="small text-muted mt-2 mb-0">Create accountant users with role <code>accountant</code> from the Users screen first.</p>
  </div>
</div>

<div class="card">
  <table class="table table-hover mb-0">
    <thead><tr><th>Accountant</th><th>Client</th><th>Since</th><th></th></tr></thead>
    <tbody>
      <% @assignments.each do |a| %>
        <tr>
          <td><%= a.accountant.email %></td>
          <td><%= a.client.email %></td>
          <td><%= a.created_at.strftime('%d %b %Y') %></td>
          <td><%= button_to 'Remove', admin_accountant_client_path(a), method: :delete, class: 'btn btn-sm btn-outline-danger', form: { data: { turbo_confirm: 'Remove assignment?' } } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<%= paginate @assignments if defined?(paginate) %>
