<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="fbr-page-header mb-0"><i class="fas fa-users text-primary"></i> Users</h1>
  <%= link_to new_admin_user_path, class: 'btn btn-primary' do %>
    <i class="fas fa-user-plus"></i> New User
  <% end %>
</div>

<%= form_with url: admin_users_path, method: :get, local: true, class: 'row g-2 mb-4 align-items-end' do |f| %>
  <div class="col-md-3">
    <%= f.label :role, 'Filter by role', class: 'form-label' %>
    <%= f.select :role, options_for_select((User::ROLES - ['admin']).map { |r| [r.humanize, r] }, params[:role]),
        { include_blank: 'All roles' },
        class: 'form-select', onchange: 'this.form.requestSubmit()' %>
  </div>
<% end %>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Email</th>
          <th>Role</th>
          <th>Business</th>
          <th>Submissions use</th>
          <th>Joined</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |u| %>
          <tr>
            <td><%= link_to u.email, admin_user_path(u) %></td>
            <td><span class="badge bg-<%= u.admin? ? 'dark' : (u.taxpayer? ? 'primary' : 'secondary') %>"><%= u.role %></span></td>
            <td><%= u.business_name.presence || '—' %></td>
            <td>
              <% if u.taxpayer? %>
                <%= user_fbr_submission_environment_display(u) %>
              <% else %>
                <span class="text-muted">—</span>
              <% end %>
            </td>
            <td><%= user_member_since(u)&.strftime('%Y-%m-%d') || '—' %></td>
            <td>
              <%= link_to 'Edit', edit_admin_user_path(u), class: 'btn btn-sm btn-outline-secondary' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= paginate @users if defined?(paginate) %>
