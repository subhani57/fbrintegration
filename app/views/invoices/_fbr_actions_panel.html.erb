<% return unless invoice.persisted? && (invoice.draft? || invoice.validated? || invoice.failed?) %>

<% submission_blocked = fbr_submission_blocked_reason(current_user, invoice: invoice) %>
<% production_mode = production_fbr_active? %>

<div class="invoice-form-fbr-panel <%= 'invoice-form-fbr-panel--production' if production_mode %>">
  <div class="invoice-form-fbr-panel__header">
    <div class="invoice-form-fbr-panel__icon">
      <i class="fas fa-<%= production_mode ? 'exclamation-triangle' : 'shield-alt' %>"></i>
    </div>
    <div class="flex-grow-1">
      <h3 class="invoice-form-fbr-panel__title">FBR submission</h3>
      <p class="invoice-form-fbr-panel__subtitle">
        <%= current_user.default_fbr_environment.humanize %> environment
        <% if production_mode %>
          <span class="badge bg-danger ms-1">Live</span>
        <% end %>
      </p>
    </div>
    <span class="badge bg-<%= status_badge_color(invoice.status) %> invoice-form-fbr-panel__status">
      <%= invoice.status&.humanize || 'Draft' %>
    </span>
  </div>

  <% if production_mode %>
    <div class="invoice-form-fbr-panel__error invoice-form-fbr-panel__error--warning">
      <i class="fas fa-exclamation-triangle"></i>
      <span>Production submissions are final and reported to FBR.</span>
    </div>
  <% end %>

  <% if submission_blocked.present? %>
    <div class="invoice-form-fbr-panel__error">
      <i class="fas fa-ban"></i>
      <span><%= submission_blocked %></span>
    </div>
  <% elsif invoice.error_message.present? %>
    <div class="invoice-form-fbr-panel__error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= invoice.error_message %></span>
    </div>
  <% end %>

  <ol class="invoice-form-fbr-panel__steps">
    <li class="invoice-form-fbr-panel__step <%= invoice.validated? ? 'invoice-form-fbr-panel__step--done' : 'invoice-form-fbr-panel__step--active' %>">
      <span class="invoice-form-fbr-panel__step-num"><%= invoice.validated? ? tag.i(class: 'fas fa-check') : '1' %></span>
      <span>Save invoice changes</span>
    </li>
    <li class="invoice-form-fbr-panel__step <%= if invoice.validated?
                                                 'invoice-form-fbr-panel__step--done'
                                               elsif invoice.failed?
                                                 'invoice-form-fbr-panel__step--active'
                                               end %>">
      <span class="invoice-form-fbr-panel__step-num"><%= invoice.validated? ? tag.i(class: 'fas fa-check') : '2' %></span>
      <span>Validate with FBR</span>
    </li>
    <li class="invoice-form-fbr-panel__step <%= invoice.validated? ? 'invoice-form-fbr-panel__step--active' : '' %>">
      <span class="invoice-form-fbr-panel__step-num">3</span>
      <span>Submit to FBR</span>
    </li>
  </ol>

  <div class="invoice-form-fbr-panel__actions">
    <%= link_to validate_invoice_path(invoice),
        class: "btn btn-outline-info w-100 #{'disabled' if submission_blocked.present?}",
        data: { turbo_method: :post }.merge(confirm_link_data(submission_blocked.blank? ? fbr_submission_confirm('validate') : nil)) do %>
      <i class="fas fa-check-circle"></i> Validate with FBR
    <% end %>
    <%= link_to submit_invoice_path(invoice),
        class: "btn btn-success w-100 #{'disabled' if submission_blocked.present?}",
        data: { turbo_method: :post }.merge(confirm_link_data(submission_blocked.blank? ? fbr_submit_confirm : nil)) do %>
      <i class="fas fa-paper-plane"></i> Submit to FBR
    <% end %>
  </div>

  <p class="invoice-form-fbr-panel__hint">
    <i class="fas fa-info-circle"></i>
    Update and save first, then validate before submitting.
  </p>
</div>
