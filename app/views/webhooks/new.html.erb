<h2 class="fbr-page-header mb-4">New webhook</h2>
<%= form_with model: @webhook, local: true do |f| %>
  <div class="mb-3"><%= f.label :url %><%= f.url_field :url, class: 'form-control', required: true %></div>
  <div class="mb-3"><%= f.label :secret %><%= f.text_field :secret, class: 'form-control' %></div>
  <div class="mb-3">
    <label class="form-label">Events</label>
    <% %w[invoice.submitted invoice.failed].each do |event| %>
      <div class="form-check"><%= check_box_tag 'webhook[events][]', event, @webhook.events.include?(event), class: 'form-check-input', id: event %><%= label_tag event, event, class: 'form-check-label' %></div>
    <% end %>
  </div>
  <%= f.submit 'Create', class: 'btn btn-primary' %>
<% end %>
