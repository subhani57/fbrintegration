<h1 class="fbr-page-header mb-4"><i class="fas fa-life-ring text-primary"></i> Support</h1>
<%= link_to 'New ticket', new_support_ticket_path, class: 'btn btn-primary mb-3' %>

<div class="card">
  <table class="table table-hover mb-0">
    <thead><tr><th>Subject</th><th>Status</th><th>Updated</th><th></th></tr></thead>
    <tbody>
      <% @tickets.each do |ticket| %>
        <tr>
          <td><%= ticket.subject %></td>
          <td><span class="badge bg-secondary"><%= ticket.status %></span></td>
          <td><%= ticket.updated_at.strftime('%d %b %Y') %></td>
          <td><%= link_to 'View', support_ticket_path(ticket), class: 'btn btn-sm btn-outline-primary' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<%= paginate @tickets if defined?(paginate) %>
