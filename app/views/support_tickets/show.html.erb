<div class="d-flex justify-content-between mb-4">
  <h1 class="fbr-page-header mb-0"><%= @ticket.subject %></h1>
  <%= link_to 'Back', support_tickets_path, class: 'btn btn-outline-secondary' %>
</div>

<div class="card mb-3"><div class="card-body">
  <span class="badge bg-secondary"><%= @ticket.status %></span>
  <span class="badge bg-light text-dark ms-1"><%= @ticket.priority %></span>
  <p class="mt-3 mb-0"><%= simple_format(@ticket.body) %></p>
</div></div>

<% @replies.each do |reply| %>
  <div class="card mb-2 <%= reply.staff_reply? ? 'border-primary' : '' %>">
    <div class="card-body py-2">
      <small class="text-muted"><%= reply.created_at.strftime('%d %b %Y %H:%M') %><%= reply.staff_reply? ? ' · Support team' : '' %></small>
      <p class="mb-0 mt-1"><%= simple_format(reply.body) %></p>
    </div>
  </div>
<% end %>

<% if @ticket.open? %>
  <%= form_with url: reply_support_ticket_path(@ticket), method: :post, local: true, class: 'card mt-3' do |f| %>
    <div class="card-body">
      <%= f.text_area :body, rows: 3, class: 'form-control mb-2', required: true %>
      <%= f.submit 'Add reply', class: 'btn btn-primary' %>
    </div>
  <% end %>
<% end %>
