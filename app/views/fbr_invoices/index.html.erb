<div class="invoice-form-page">
  <div class="invoice-form-hero">
    <div class="invoice-form-hero__content">
      <div class="invoice-form-hero__icon"><i class="fas fa-cloud-download-alt"></i></div>
      <div>
        <h1 class="invoice-form-hero__title">FBR / IRIS Invoices</h1>
        <p class="invoice-form-hero__subtitle">
          Download official PDFs for invoices registered on FBR Digital Invoicing (same records visible in IRIS portal).
        </p>
      </div>
    </div>
    <%= link_to 'https://iris.fbr.gov.pk', target: '_blank', rel: 'noopener', class: 'btn btn-light btn-sm invoice-form-hero__back' do %>
      <i class="fas fa-external-link-alt"></i> Open IRIS Portal
    <% end %>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card fbr-stat-card"><div class="card-body py-3">
        <small class="text-muted">On FBR</small>
        <div class="h4 mb-0 text-primary"><%= @stats[:total] %></div>
      </div></div>
    </div>
    <div class="col-md-4">
      <div class="card fbr-stat-card"><div class="card-body py-3">
        <small class="text-muted">Submitted this month</small>
        <div class="h4 mb-0"><%= @stats[:this_month] %></div>
      </div></div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="h6 text-primary mb-3"><i class="fas fa-search"></i> Look up FBR invoice number</h2>
      <%= form_with url: lookup_fbr_invoices_path, method: :post, local: true, class: 'row g-2 align-items-end' do |f| %>
        <div class="col-md-8">
          <%= f.label :fbr_invoice_number, 'FBR invoice number (from IRIS or submission response)', class: 'form-label' %>
          <%= f.text_field :fbr_invoice_number, class: 'form-control', placeholder: 'e.g. 7000007DI1747119701593', required: true %>
        </div>
        <div class="col-md-4">
          <%= f.submit 'Look up on FBR', class: 'btn btn-primary w-100' %>
        </div>
      <% end %>
      <p class="small text-muted mt-2 mb-0">
        Uses your FBR API token to query FBR. If the invoice was submitted through this app, you can download the PDF even when live lookup is unavailable.
      </p>
    </div>
  </div>

  <%= form_with url: fbr_invoices_path, method: :get, local: true, class: 'row g-2 mb-3' do |f| %>
    <div class="col-md-5">
      <%= f.text_field :q, value: params[:q], placeholder: 'Search FBR #, invoice #, buyer…', class: 'form-control' %>
    </div>
    <div class="col-md-2">
      <%= f.submit 'Search', class: 'btn btn-outline-primary' %>
    </div>
  <% end %>

  <% if @invoices.any? %>
    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>FBR Invoice #</th>
              <th>Your Invoice #</th>
              <th>Date</th>
              <th>Buyer</th>
              <th>Amount</th>
              <th>Submitted</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @invoices.each do |inv| %>
              <tr>
                <td><code class="small"><%= inv.fbr_invoice_id %></code></td>
                <td><%= link_to inv.invoice_number, invoice_path(inv) %></td>
                <td><%= inv.invoice_date %></td>
                <td><%= inv.buyer_name %></td>
                <td><%= number_to_currency(inv.total_amount, unit: 'Rs. ') %></td>
                <td><%= inv.submitted_at&.strftime('%d %b %Y') || '—' %></td>
                <td class="text-nowrap">
                  <%= link_to download_pdf_fbr_invoice_path(inv), class: 'btn btn-sm btn-success' do %>
                    <i class="fas fa-download"></i> PDF
                  <% end %>
                  <%= link_to fbr_invoice_path(inv), class: 'btn btn-sm btn-outline-primary' do %>
                    <i class="fas fa-eye"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% if @invoices.respond_to?(:total_count) %>
      <%= render 'shared/pagination_footer',
          collection: @invoices,
          form_path: fbr_invoices_path,
          per_options: [20],
          item_label: 'invoices',
          extra_params: params.permit(:q, :from, :to).to_h.compact %>
    <% end %>
    </div>
  <% else %>
    <div class="card fbr-empty-state">
      <div class="card-body py-5 text-center">
        <i class="fas fa-cloud fa-3x text-muted mb-3"></i>
        <h4>No FBR invoices yet</h4>
        <p class="text-muted">Submit invoices to FBR — they will appear here for download.</p>
        <%= link_to invoices_path, class: 'btn btn-primary' do %>
          <i class="fas fa-file-invoice"></i> Go to Invoices
        <% end %>
      </div>
    </div>
  <% end %>
</div>
