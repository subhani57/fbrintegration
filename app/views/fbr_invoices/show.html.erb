<div class="invoice-form-page">
  <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
      <h1 class="fbr-page-header mb-1">FBR Invoice</h1>
      <code class="fs-6"><%= @invoice.fbr_invoice_id %></code>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <%= link_to download_pdf_fbr_invoice_path(@invoice), class: 'btn btn-success' do %>
        <i class="fas fa-download"></i> Download FBR PDF
      <% end %>
      <% if current_user.can_manage_invoices? %>
        <%= button_to sync_from_fbr_fbr_invoice_path(@invoice), method: :post, class: 'btn btn-outline-primary' do %>
          <i class="fas fa-sync"></i> Sync from FBR
        <% end %>
        <% if policy(@invoice).mark_cancelled_on_iris? %>
          <%= button_to mark_cancelled_on_iris_invoice_path(@invoice),
              method: :post,
              class: 'btn btn-outline-warning',
              form: { data: confirm_form_data('Confirm this invoice was cancelled on the IRIS portal?') } do %>
            <i class="fas fa-ban"></i> Mark cancelled on IRIS
          <% end %>
        <% end %>
      <% end %>
      <%= link_to fbr_invoices_path, class: 'btn btn-outline-secondary' do %>
        <i class="fas fa-arrow-left"></i> Back
      <% end %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card mb-3">
        <div class="card-header fw-semibold">Invoice summary</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="text-muted small">Your reference</label>
              <div><%= link_to @invoice.invoice_number, invoice_path(@invoice) %></div>
            </div>
            <div class="col-md-6">
              <label class="text-muted small">Invoice date</label>
              <div><%= @invoice.invoice_date.strftime('%d %B %Y') %></div>
            </div>
            <div class="col-md-6">
              <label class="text-muted small">Buyer</label>
              <div><%= @invoice.buyer_name %></div>
            </div>
            <div class="col-md-6">
              <label class="text-muted small">Grand total</label>
              <div class="fw-bold text-primary"><%= number_to_currency(@invoice.total_amount, unit: 'Rs. ') %></div>
            </div>
          </div>
        </div>
      </div>

      <% if @invoice.response_data.present? %>
        <div class="card">
          <div class="card-header fw-semibold">FBR response data</div>
          <div class="card-body">
            <pre class="small bg-light p-3 rounded mb-0" style="max-height: 320px; overflow: auto;"><%= JSON.pretty_generate(@invoice.response_data) %></pre>
          </div>
        </div>
      <% end %>
    </div>

    <div class="col-lg-4">
      <div class="invoice-form-sidebar-tip mb-3">
        <i class="fas fa-info-circle"></i>
        <p class="mb-0">
          FBR does not expose a public PDF download API in production. This app generates a compliant PDF with your FBR invoice number and QR code — matching IRIS portal records.
        </p>
      </div>
      <%= link_to @invoice.iris_verification_url, target: '_blank', rel: 'noopener', class: 'btn btn-outline-secondary w-100' do %>
        <i class="fas fa-external-link-alt"></i> Verify on IRIS Portal
      <% end %>
    </div>
  </div>
</div>
