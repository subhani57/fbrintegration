<%# locals: user, form_path_helper, embedded: false - form_path_helper is a lambda (environment) -> path %>
<% embedded = local_assigns.fetch(:embedded, false) %>
<div class="<%= embedded ? '' : 'border-bottom pb-3 mb-3' %>">
  <% unless embedded %>
    <h6 class="mb-2"><i class="fas fa-bolt text-primary"></i> Active environment for submissions</h6>
    <p class="text-muted small mb-2">
      Choose which token is used when this user validates or submits invoices.
    </p>
  <% end %>
  <div class="d-flex flex-wrap gap-2 align-items-center">
    <% FbrConfiguration::ENVIRONMENTS.each do |environment| %>
      <% switch_blocked = Fbr::EnvironmentGuard.switch_environment_blocked_reason(user, environment) %>
      <% if switch_blocked.present? && user.default_fbr_environment != environment %>
        <span class="btn btn-sm btn-outline-secondary disabled" title="<%= switch_blocked %>">
          <%= environment.humanize %>
        </span>
      <% else %>
        <% link_data = { turbo_method: :patch } %>
        <% if environment == 'production' && user.default_fbr_environment != 'production' %>
          <% link_data.merge!(confirm_link_data('Switch to Production? Live FBR submissions will be used.')) %>
        <% end %>
        <%= link_to form_path_helper.call(environment),
            data: link_data,
            class: "btn btn-sm #{user.default_fbr_environment == environment ? 'btn-primary' : 'btn-outline-primary'}" do %>
          <% if user.default_fbr_environment == environment %>
            <i class="fas fa-check-circle me-1"></i>
          <% end %>
          <%= environment.humanize %>
        <% end %>
      <% end %>
    <% end %>
  </div>
  <% unless embedded %>
    <p class="text-muted small mb-0 mt-2">
      Current: <%= user_fbr_submission_environment_display(user) %>
    </p>
  <% end %>
</div>
