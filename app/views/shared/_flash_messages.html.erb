<% if notice %>
  <div class="alert alert-success fbr-flash alert-dismissible fade show" role="alert" data-fbr-flash-variant="success">
    <i class="fas fa-check-circle me-2" aria-hidden="true"></i>
    <span class="fbr-flash__text"><%= notice %></span>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>

<% if alert %>
  <div class="alert alert-danger fbr-flash alert-dismissible fade show" role="alert" data-fbr-flash-variant="danger">
    <i class="fas fa-exclamation-circle me-2" aria-hidden="true"></i>
    <span class="fbr-flash__text"><%= alert %></span>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% end %>
