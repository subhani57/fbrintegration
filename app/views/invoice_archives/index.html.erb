<h1 class="fbr-page-header mb-4"><i class="fas fa-archive text-primary"></i> Submitted Invoice Archive</h1>

<%= form_with url: invoice_archives_path, method: :get, local: true, class: 'row g-2 mb-4' do |f| %>
  <div class="col-md-6"><%= f.text_field :q, value: params[:q], class: 'form-control', placeholder: 'Search FBR ID, buyer…' %></div>
  <div class="col-md-2"><%= f.submit 'Search', class: 'btn btn-primary w-100' %></div>
<% end %>

<%= form_with url: export_invoice_archives_path, method: :post, local: true, html: { data: { turbo: false } } do %>
  <div class="card mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
      <span class="text-muted">Select invoices below, then export PDFs as ZIP</span>
      <%= submit_tag 'Export selected PDFs', class: 'btn btn-success' %>
    </div>
  </div>
  <div class="card">
    <table class="table table-hover mb-0">
      <thead><tr><th></th><th>Invoice</th><th>FBR ID</th><th>Buyer</th><th>Submitted</th><th></th></tr></thead>
      <tbody>
        <% @invoices.each do |inv| %>
          <tr>
            <td><%= check_box_tag 'invoice_ids[]', inv.id, false %></td>
            <td><%= inv.pdf_display_number %></td>
            <td><code class="small"><%= inv.fbr_invoice_id %></code></td>
            <td><%= inv.buyer_name %></td>
            <td><%= inv.submitted_at&.strftime('%d %b %Y') %></td>
            <td><%= link_to 'View', invoice_path(inv), class: 'btn btn-sm btn-outline-primary' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
<%= paginate @invoices if defined?(paginate) %>
