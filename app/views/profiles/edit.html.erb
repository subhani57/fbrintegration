<div class="row justify-content-center">
  <div class="col-lg-10">
    <h1 class="fbr-page-header mb-4 h3">
      <i class="fas fa-user-edit text-primary"></i> Edit Business &amp; FBR Settings
    </h1>

    <%= form_with model: @user, url: profile_path, method: :patch, local: true, html: { multipart: true } do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold"><i class="fas fa-id-card me-1"></i> Business profile</div>
        <div class="card-body">
          <div class="mb-3">
            <%= f.label :ntn_cnic, 'NTN / CNIC', class: 'form-label' %>
            <%= f.text_field :ntn_cnic, class: 'form-control', placeholder: 'e.g. 1234567-8' %>
            <div class="form-text">Your registered NTN or CNIC as required by FBR.</div>
          </div>

          <div class="mb-3">
            <%= f.label :business_name, 'Business Name', class: 'form-label' %>
            <%= f.text_field :business_name, class: 'form-control', placeholder: 'Registered business name' %>
          </div>

          <div class="mb-3">
            <%= f.label :address, 'Business Address', class: 'form-label' %>
            <%= f.text_area :address, class: 'form-control', rows: 3, placeholder: 'Full business address' %>
          </div>

          <div class="mb-0">
            <%= f.label :company_logo, 'Company Logo', class: 'form-label' %>
            <% if @user.company_logo.present? %>
              <div class="mb-2">
                <%= image_tag @user.company_logo.thumb.url, alt: 'Current company logo', class: 'img-thumbnail', style: 'max-height: 120px' %>
              </div>
              <div class="form-check mb-2">
                <%= f.check_box :remove_company_logo, class: 'form-check-input' %>
                <%= f.label :remove_company_logo, 'Remove current logo', class: 'form-check-label' %>
              </div>
            <% end %>
            <%= f.file_field :company_logo, class: 'form-control', accept: 'image/png,image/jpeg,image/gif,image/webp' %>
            <div class="form-text">Shown on downloaded invoice PDFs.</div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold"><i class="fas fa-cogs me-1"></i> FBR API tokens</div>
        <div class="card-body">
          <%= render 'shared/fbr_preferred_environment',
              user: @user,
              form_path_helper: ->(environment) { preferred_environment_profile_path(environment: environment) } %>

          <% FbrConfiguration::ENVIRONMENTS.each_with_index do |environment, index| %>
            <% config = @configs_by_environment[environment] %>
            <div class="<%= index < FbrConfiguration::ENVIRONMENTS.length - 1 ? 'mb-4 pb-4 border-bottom' : 'mb-0' %>">
              <div class="d-flex align-items-center gap-2 mb-2">
                <%= fbr_environment_badge(environment) %>
                <% if environment == @user.default_fbr_environment %>
                  <span class="badge bg-success">Current for submissions</span>
                <% end %>
              </div>
              <label class="form-label" for="fbr_configurations_<%= environment %>_token">
                FBR Security Token
              </label>
              <input type="text"
                     name="fbr_configurations[<%= environment %>][token]"
                     id="fbr_configurations_<%= environment %>_token"
                     class="form-control"
                     autocomplete="off"
                     placeholder="<%= config.token_configured? ? 'Enter new token to replace existing' : 'Paste your FBR API token' %>"
                     value="">
              <% if config.token_configured? %>
                <div class="form-text text-success">
                  <i class="fas fa-check-circle"></i> Token configured — leave blank to keep the current token.
                </div>
              <% else %>
                <div class="form-text">From FBR IRIS → Digital Invoicing for the <%= environment.humanize %> environment.</div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit 'Save Settings', class: 'btn btn-primary' %>
        <%= link_to 'Cancel', profile_path, class: 'btn btn-outline-secondary' %>
      </div>
    <% end %>
  </div>
</div>
