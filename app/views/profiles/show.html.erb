<div class="row justify-content-center">
  <div class="col-lg-10">
    <div class="fbr-page-header d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
      <h1 class="mb-0 h3">
        <i class="fas fa-building text-primary"></i> Business &amp; FBR Settings
      </h1>
      <%= link_to edit_profile_path, class: 'btn btn-primary' do %>
        <i class="fas fa-edit"></i> Edit Settings
      <% end %>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header fw-semibold"><i class="fas fa-id-card me-1"></i> Business profile</div>
      <div class="card-body">
        <p class="text-muted mb-4">
          Seller details used on invoices and when submitting to FBR.
        </p>

        <dl class="row mb-0">
          <dt class="col-sm-4">Email</dt>
          <dd class="col-sm-8"><%= @user.email %></dd>

          <dt class="col-sm-4">NTN / CNIC</dt>
          <dd class="col-sm-8"><%= @user.ntn_cnic.presence || content_tag(:span, 'Not set', class: 'text-muted') %></dd>

          <dt class="col-sm-4">Business Name</dt>
          <dd class="col-sm-8"><%= @user.business_name.presence || content_tag(:span, 'Not set', class: 'text-muted') %></dd>

          <dt class="col-sm-4">Address</dt>
          <dd class="col-sm-8">
            <% if @user.address.present? %>
              <%= simple_format(@user.address, class: 'mb-0') %>
            <% else %>
              <span class="text-muted">Not set</span>
            <% end %>
          </dd>

          <dt class="col-sm-4">Company Logo</dt>
          <dd class="col-sm-8">
            <% if @user.company_logo.present? %>
              <%= image_tag @user.company_logo.thumb.url, alt: 'Company logo', class: 'img-thumbnail', style: 'max-height: 120px' %>
            <% else %>
              <span class="text-muted">No logo uploaded</span>
            <% end %>
          </dd>
        </dl>
      </div>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header fw-semibold"><i class="fas fa-cogs me-1"></i> FBR API tokens</div>
      <div class="card-body">
        <%= render 'shared/fbr_preferred_environment',
            user: @user,
            form_path_helper: ->(environment) { preferred_environment_profile_path(environment: environment) } %>

        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead>
              <tr>
                <th>Environment</th>
                <th>Status</th>
                <th>Token</th>
              </tr>
            </thead>
            <tbody>
              <% FbrConfiguration::ENVIRONMENTS.each do |environment| %>
                <% config = @configs_by_environment[environment] %>
                <tr>
                  <td>
                    <%= fbr_environment_badge(environment) %>
                    <% if environment == @user.default_fbr_environment %>
                      <span class="badge bg-success ms-1">Current</span>
                    <% end %>
                  </td>
                  <td>
                    <% if config&.token_configured? %>
                      <span class="text-success"><i class="fas fa-check-circle"></i> Ready</span>
                    <% else %>
                      <span class="text-muted"><i class="fas fa-minus-circle"></i> Not configured</span>
                    <% end %>
                  </td>
                  <td>
                    <% if config&.token_configured? %>
                      <code>••••••••</code>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <p class="text-muted small mb-0 mt-3">
          <i class="fas fa-info-circle text-primary me-1"></i>
          <strong>Sandbox</strong> for testing · <strong>Production</strong> for live FBR submissions.
          Use <strong>Edit Settings</strong> to update tokens.
        </p>
      </div>
    </div>
  </div>
</div>
