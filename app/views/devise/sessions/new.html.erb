<% content_for :auth_title, 'Sign In' %>

<div class="auth-card">
  <div class="auth-card__icon">
    <i class="fas fa-user-lock"></i>
  </div>

  <h2 class="auth-card__title">Welcome back</h2>
  <p class="auth-card__subtitle">Sign in to manage your FBR invoices</p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name),
      html: { class: 'auth-form', data: { turbo: false } }) do |f| %>
    <div class="auth-field">
      <%= f.label :email, class: 'auth-label' %>
      <div class="auth-input-wrap">
        <i class="fas fa-envelope auth-input-icon"></i>
        <%= f.email_field :email, autofocus: true, autocomplete: 'email',
            class: 'form-control auth-input', placeholder: 'you@company.com' %>
      </div>
    </div>

    <div class="auth-field">
      <%= f.label :password, class: 'auth-label' %>
      <div class="auth-input-wrap">
        <i class="fas fa-lock auth-input-icon"></i>
        <%= f.password_field :password, autocomplete: 'current-password',
            class: 'form-control auth-input', placeholder: 'Your password' %>
      </div>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="auth-remember">
        <%= f.check_box :remember_me, class: 'form-check-input' %>
        <%= f.label :remember_me, 'Keep me signed in', class: 'form-check-label' %>
      </div>
    <% end %>

    <%= f.submit 'Sign In', class: 'btn btn-primary auth-submit w-100' %>
  <% end %>

  <%= render 'devise/shared/links' %>
</div>
