<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FBR Digital Invoicing — <%= content_for?(:auth_title) ? yield(:auth_title) : 'Sign In' %></title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= javascript_importmap_tags %>
</head>
<body class="auth-body">
  <div class="auth-page">
    <aside class="auth-brand" aria-hidden="true">
      <div class="auth-brand__inner">
        <div class="auth-brand__logo">
          <i class="fas fa-file-invoice-dollar"></i>
        </div>
        <h1 class="auth-brand__title">FBR Digital Invoicing</h1>
        <p class="auth-brand__tagline">Create, validate, and submit sales tax invoices to the Federal Board of Revenue — all in one place.</p>

        <ul class="auth-brand__features">
          <li><i class="fas fa-check-circle"></i> FBR-compliant invoice submission</li>
          <li><i class="fas fa-check-circle"></i> Branded PDF downloads with your logo</li>
          <li><i class="fas fa-check-circle"></i> Secure taxpayer dashboard</li>
        </ul>

        <p class="auth-brand__footer">
          <i class="fas fa-shield-alt"></i> Trusted by Pakistani businesses
        </p>
      </div>
      <div class="auth-brand__orb auth-brand__orb--1"></div>
      <div class="auth-brand__orb auth-brand__orb--2"></div>
    </aside>

    <main class="auth-main fbr-main-content">
      <div class="auth-main__content">
        <%= render "shared/flash_messages" %>

        <%= yield %>
      </div>

      <p class="auth-main__copyright">
        &copy; <%= Time.current.year %> FBR Digital Invoicing System
      </p>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <div id="fbr-portal" data-turbo-permanent></div>
</body>
</html>
