<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin — FBR Digital Invoicing</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= yield :head %>
  <%= javascript_importmap_tags %>
</head>
<body class="fbr-app admin-portal">
  <nav class="navbar navbar-expand-lg navbar-dark navbar-fbr navbar-fbr--admin" id="fbr-admin-navbar">
    <div class="container-fluid">
      <%= link_to admin_dashboard_path, class: 'navbar-brand' do %>
        <i class="fas fa-shield-alt"></i> FBR Admin
      <% end %>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbarNav" aria-controls="adminNavbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="adminNavbarNav">
        <ul class="navbar-nav me-auto fbr-main-nav">
          <%= render 'shared/nav/admin_nav' %>
        </ul>
        <ul class="navbar-nav align-items-center gap-1 fbr-nav-actions">
          <%= render 'shared/nav/user_menu' %>
        </ul>
      </div>
    </div>
  </nav>

  <%= render "shared/flash_messages" %>

  <main class="admin-main py-4 fbr-main-content">
    <div class="container-fluid">
      <%= yield %>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <%= render "shared/fbr_ui_boot" %>
  <div id="fbr-portal" data-turbo-permanent></div>
</body>
</html>
