<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FBR Digital Invoicing System</title>
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- App theme (after Bootstrap so overrides apply) -->
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Flatpickr (invoice date picker) -->
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  
  <%= yield :head %>

  <%= javascript_importmap_tags %>
</head>
<body class="fbr-app" data-fbr-environment="<%= user_signed_in? && current_user.taxpayer? ? current_user.default_fbr_environment : '' %>">
  <!-- Navigation (persistent across Turbo visits) -->
  <nav class="navbar navbar-expand-lg navbar-dark navbar-fbr" id="fbr-main-navbar">
    <div class="container-fluid">
      <%= link_to root_path, class: 'navbar-brand' do %>
        <i class="fas fa-file-invoice-dollar"></i> FBR Invoicing
      <% end %>
      
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto fbr-main-nav">
          <% if user_signed_in? && current_user.can_access_taxpayer_portal? %>
            <%= render 'shared/nav/taxpayer_nav' %>
          <% elsif user_signed_in? && current_user.admin? %>
            <%= render 'shared/nav/admin_nav' %>
          <% end %>
        </ul>

        <ul class="navbar-nav align-items-center gap-2 fbr-nav-actions">
          <% if user_signed_in? && current_user.can_access_taxpayer_portal? && current_user.can_manage_invoices? %>
            <li class="nav-item">
              <%= link_to new_invoice_path, class: 'btn btn-light btn-sm fbr-nav-new-invoice' do %>
                <i class="fas fa-plus me-1"></i> New Invoice
              <% end %>
            </li>
          <% end %>
          <%= render 'shared/fbr_navbar_environment_switcher' if user_signed_in? && current_user.can_access_taxpayer_portal? %>
          <% if user_signed_in? %>
            <%= render 'shared/nav/user_menu' %>
          <% else %>
            <li class="nav-item">
              <%= link_to 'Login', new_user_session_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to new_user_registration_path, class: 'btn btn-light auth-nav-register' do %>
                <i class="fas fa-user-plus me-1"></i> Register
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Flash Messages (converted to floating notifications by JS) -->
  <div id="fbr-flash-slot">
    <%= render "shared/flash_messages" %>
  </div>

  <div id="fbr-environment-banner">
    <%= render 'shared/fbr_environment_banner' %>
  </div>

  <%= render 'shared/subscription_expiry_banner' if user_signed_in? %>
  <%= render 'shared/managed_client_banner' if user_signed_in? && managed_client? %>

  <!-- Main Content -->
  <div class="container-fluid mt-3 fbr-main-content">
    <%= yield %>
  </div>

  <!-- Footer -->
  <footer class="footer fbr-footer mt-5 py-4">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <p class="text-muted mb-0">
            <i class="fas fa-copyright"></i> <%= Time.current.year %> FBR Digital Invoicing System
          </p>
        </div>
        <div class="col-md-6 text-end">
          <p class="text-muted mb-0">
            <i class="fas fa-headset"></i> Support: support@fbr-invoicing.com
          </p>
        </div>
      </div>
    </div>
  </footer>

  <!-- jQuery for Select2 -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <%= render "shared/fbr_ui_boot" %>

  <div id="fbr-portal" data-turbo-permanent></div>
</body>
</html>