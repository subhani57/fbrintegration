<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FBR Digital Invoicing System</title>
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- App theme (after Bootstrap so overrides apply) -->
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- Flatpickr (invoice date picker) -->
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  
  <%= yield :head %>
</head>
<body class="fbr-app">
  <!-- Navigation (persistent across Turbo visits) -->
  <nav class="navbar navbar-expand-lg navbar-dark navbar-fbr" id="fbr-main-navbar" data-turbo-permanent>
    <div class="container-fluid">
      <%= link_to root_path, class: 'navbar-brand' do %>
        <i class="fas fa-file-invoice-dollar"></i> FBR Invoicing
      <% end %>
      
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <% if user_signed_in? && current_user.can_access_taxpayer_portal? %>
            <li class="nav-item">
              <%= link_to dashboard_path, class: "nav-link #{'active' if current_page?(dashboard_path)}" do %>
                <i class="fas fa-tachometer-alt"></i> Dashboard
              <% end %>
            </li>
            <li class="nav-item">
              <%= link_to invoices_path, class: "nav-link #{'active' if controller_name == 'invoices'}" do %>
                <i class="fas fa-file-invoice"></i> Invoices
              <% end %>
            </li>
            <li class="nav-item">
              <%= link_to fbr_invoices_path, class: "nav-link #{'active' if controller_name == 'fbr_invoices'}" do %>
                <i class="fas fa-cloud-download-alt"></i> FBR Downloads
              <% end %>
            </li>
            <li class="nav-item">
              <%= link_to reports_path, class: "nav-link #{'active' if current_page?(reports_path)}" do %>
                <i class="fas fa-chart-bar"></i> Reports
              <% end %>
            </li>
            <% if current_user.can_manage_invoices? %>
              <li class="nav-item">
                <%= link_to companies_path, class: "nav-link #{'active' if controller_name == 'companies'}" do %>
                  <i class="fas fa-building"></i> Companies
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to profile_path, class: "nav-link #{'active' if controller_name == 'profiles'}" do %>
                  <i class="fas fa-cogs"></i> Settings
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to invoice_templates_path, class: "nav-link #{'active' if controller_name == 'invoice_templates'}" do %>
                  <i class="fas fa-copy"></i> Templates
                <% end %>
              </li>
              <li class="nav-item">
                <%= link_to webhooks_path, class: "nav-link #{'active' if controller_name == 'webhooks'}" do %>
                  <i class="fas fa-plug"></i> Webhooks
                <% end %>
              </li>
            <% end %>
            <li class="nav-item">
              <%= link_to notifications_path, class: "nav-link #{'active' if controller_name == 'notifications'}" do %>
                <i class="fas fa-bell"></i> Notifications
                <% unread = current_user.notifications.unread.count %>
                <% if unread.positive? %><span class="badge bg-danger"><%= unread %></span><% end %>
              <% end %>
            </li>
          <% elsif user_signed_in? && current_user.admin? %>
            <li class="nav-item">
              <%= link_to admin_dashboard_path, class: "nav-link #{'active' if request.path.start_with?('/admin')}" do %>
                <i class="fas fa-shield-alt"></i> Admin Portal
              <% end %>
            </li>
          <% end %>
        </ul>
        
        <ul class="navbar-nav align-items-center gap-1">
          <%= render 'shared/fbr_navbar_environment_switcher' %>
          <% if user_signed_in? %>
            <li class="nav-item dropdown" data-controller="navbar-dropdown">
              <button type="button"
                      class="nav-link dropdown-toggle btn btn-link border-0 text-start"
                      id="userDropdown"
                      data-navbar-dropdown-target="button"
                      data-action="click->navbar-dropdown#toggle"
                      aria-expanded="false"
                      aria-haspopup="true">
                <i class="fas fa-user-circle"></i> <%= current_user.email %>
              </button>
              <div class="dropdown-menu dropdown-menu-end" data-navbar-dropdown-target="menu">
                <% if current_user.can_manage_invoices? %>
                  <%= link_to profile_path, class: 'dropdown-item' do %>
                    <i class="fas fa-building"></i> Business &amp; FBR Settings
                  <% end %>
                <% elsif current_user.admin? %>
                  <%= link_to admin_dashboard_path, class: 'dropdown-item' do %>
                    <i class="fas fa-shield-alt"></i> Admin Portal
                  <% end %>
                <% end %>
                <div class="dropdown-divider"></div>
                <%= link_to destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: 'dropdown-item' do %>
                  <i class="fas fa-sign-out-alt me-2"></i> Logout
                <% end %>
              </div>
            </li>
          <% else %>
            <li class="nav-item">
              <%= link_to 'Login', new_user_session_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to new_user_registration_path, class: 'btn btn-light auth-nav-register' do %>
                <i class="fas fa-user-plus me-1"></i> Register
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Flash Messages (converted to floating notifications by JS) -->
  <%= render "shared/flash_messages" %>

  <%= render 'shared/fbr_environment_banner' %>

  <!-- Main Content -->
  <div class="container-fluid mt-3 fbr-main-content">
    <%= yield %>
  </div>

  <!-- Footer -->
  <footer class="footer fbr-footer mt-5 py-4">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <p class="text-muted mb-0">
            <i class="fas fa-copyright"></i> <%= Time.current.year %> FBR Digital Invoicing System
          </p>
        </div>
        <div class="col-md-6 text-end">
          <p class="text-muted mb-0">
            <i class="fas fa-headset"></i> Support: support@fbr-invoicing.com
          </p>
        </div>
      </div>
    </div>
  </footer>

  <!-- jQuery for Select2 -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  
  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <!-- Application JS -->
  <%= javascript_importmap_tags %>
</body>
</html>