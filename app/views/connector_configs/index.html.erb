<h1 class="fbr-page-header mb-4"><i class="fas fa-link text-primary"></i> Connectors</h1>

<%= form_with model: ConnectorConfig.new, url: connector_configs_path, local: true, class: 'card mb-4' do |f| %>
  <div class="card-body row g-2">
    <div class="col-md-4"><%= f.text_field :name, class: 'form-control', placeholder: 'Name', required: true %></div>
    <div class="col-md-4"><%= f.select :provider, ConnectorConfig::PROVIDERS, {}, class: 'form-select' %></div>
    <div class="col-md-2"><%= f.submit 'Add', class: 'btn btn-primary w-100' %></div>
  </div>
<% end %>

<% @connectors.each do |connector| %>
  <div class="card mb-3">
    <div class="card-body">
      <div class="d-flex justify-content-between">
        <div>
          <strong><%= connector.name %></strong>
          <span class="badge bg-secondary ms-1"><%= connector.provider %></span>
        </div>
        <%= button_to 'Remove', connector_config_path(connector), method: :delete, class: 'btn btn-sm btn-outline-danger' %>
      </div>
      <%= form_with url: test_connector_config_path(connector), method: :post, local: true, class: 'mt-3' do %>
        <%= text_area_tag :payload, '{"buyer_name":"Test Buyer","items":[{"description":"Item","quantity":1,"unit_price":1000}]}', rows: 3, class: 'form-control font-monospace small mb-2' %>
        <%= submit_tag 'Test JSON import', class: 'btn btn-sm btn-outline-primary' %>
      <% end %>
    </div>
  </div>
<% end %>
