<h2 class="fbr-page-header mb-4"><i class="fas fa-copy text-primary"></i> Invoice templates</h2>
<% if @templates.any? %>
  <div class="list-group">
    <% @templates.each do |t| %>
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <%= link_to t.name, new_invoice_path(template_id: t.id), class: 'fw-semibold' %>
        <%= button_to 'Delete', invoice_template_path(t), method: :delete, class: 'btn btn-sm btn-outline-danger', data: { turbo_confirm: 'Delete template?' } %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">No templates yet. Save one from an invoice page.</p>
<% end %>
