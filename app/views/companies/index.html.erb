<div class="row">
  <div class="col-12">
    <div class="fbr-page-header d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
      <div>
        <h2 class="mb-0"><i class="fas fa-building text-primary"></i> Buyer Companies</h2>
        <% if @companies.any? %>
          <p class="text-muted small mb-0 mt-1"><%= @companies.size %> saved buyer<%= @companies.size == 1 ? '' : 's' %></p>
        <% end %>
      </div>
      <%= link_to new_company_path, class: 'btn btn-primary' do %>
        <i class="fas fa-plus"></i> Add Company
      <% end %>
    </div>

    <p class="text-muted small mb-4">
      Save buyers you invoice often — pick them quickly on the new invoice form.
      Province defaults to <strong>Punjab</strong> and registration type to <strong>Registered</strong>.
    </p>

    <% if @companies.any? %>
      <div class="card">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover table-sm fbr-invoice-table mb-0">
              <thead>
                <tr>
                  <th style="width: 24%">Business name</th>
                  <th style="width: 14%">NTN / CNIC</th>
                  <th style="width: 14%">Phone</th>
                  <th style="width: 38%">Address</th>
                  <th class="fbr-invoice-table__actions fbr-invoice-table__actions--compact">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @companies.each do |company| %>
                  <tr>
                    <td class="text-truncate"><strong><%= company.name %></strong></td>
                    <td class="text-nowrap"><%= company.ntn %></td>
                    <td class="text-nowrap small text-muted"><%= company.phone.presence || '—' %></td>
                    <td class="fbr-invoice-table__buyer" title="<%= company.address %>"><%= company.address.presence || '—' %></td>
                    <td class="fbr-invoice-table__actions fbr-invoice-table__actions--compact">
                      <div class="d-flex align-items-center justify-content-end gap-1">
                        <%= link_to edit_company_path(company), class: 'btn btn-outline-primary btn-sm', aria: { label: "Edit #{company.name}" } do %>
                          <i class="fas fa-edit"></i>
                        <% end %>
                        <%= button_to company_path(company),
                            method: :delete,
                            class: 'btn btn-outline-danger btn-sm',
                            aria: { label: "Delete #{company.name}" },
                            form: { class: 'd-inline', data: confirm_form_data("Delete #{company.name}?") } do %>
                          <i class="fas fa-trash"></i>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% else %>
      <div class="card fbr-empty-state">
        <div class="card-body py-5 text-center">
          <i class="fas fa-building fa-4x mb-3 text-muted"></i>
          <h4 class="text-muted">No buyer companies yet</h4>
          <p class="text-muted mb-4">Add companies you invoice often — they will appear on the new invoice form.</p>
          <%= link_to new_company_path, class: 'btn btn-primary' do %>
            <i class="fas fa-plus"></i> Add your first company
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
