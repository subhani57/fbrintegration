<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="fbr-page-header mb-4">
      <h2 class="mb-0 h3"><%= title %></h2>
      <p class="text-muted small mb-0 mt-1">Buyer details used when creating invoices</p>
    </div>

    <div class="card">
      <div class="card-body">
        <%= form_with model: company, local: true do |f| %>
          <% if company.errors.any? %>
            <div class="alert alert-danger">
              <%= company.errors.full_messages.join(', ') %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :name, 'Buyer business name', class: 'form-label' %>
            <%= f.text_field :name, class: 'form-control', required: true, placeholder: 'Registered business name' %>
          </div>

          <div class="mb-3">
            <%= f.label :ntn, 'Buyer NTN / CNIC', class: 'form-label' %>
            <%= f.text_field :ntn, class: 'form-control', required: true, placeholder: 'e.g. 1234567-8' %>
          </div>

          <div class="mb-3">
            <%= f.label :address, 'Buyer address', class: 'form-label' %>
            <%= f.text_area :address, class: 'form-control', rows: 3, placeholder: 'Full business address' %>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <%= f.label :phone, 'Phone (optional)', class: 'form-label' %>
              <%= f.text_field :phone, class: 'form-control' %>
            </div>
            <div class="col-md-6">
              <%= f.label :email, 'Email (optional)', class: 'form-label' %>
              <%= f.email_field :email, class: 'form-control' %>
            </div>
          </div>

          <div class="alert alert-light border small mb-4">
            <i class="fas fa-info-circle text-primary me-1"></i>
            <strong>Province:</strong> Punjab · <strong>Registration type:</strong> Registered (fixed for all buyer companies)
          </div>

          <div class="d-flex flex-wrap gap-2 pt-2">
            <%= f.submit company.persisted? ? 'Save changes' : 'Add company', class: 'btn btn-primary' %>
            <%= link_to 'Cancel', companies_path, class: 'btn btn-outline-secondary' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
